<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Innovation &mdash; {{ table_id }}</title>
<link href="https://fonts.googleapis.com/css2?family=Russo+One&family=Barlow+Condensed&display=swap" rel="stylesheet">
<style>
{% include "summary.css" %}
</style>
</head>
<body>
{%- from "macros.html.j2" import render_item, tri_toggle, section_row -%}
{%- set _eye_open %}{% include "icons/eye_open.svg" %}{% endset -%}
{%- set _eye_closed %}{% include "icons/eye_closed.svg" %}{% endset -%}
{%- set _question %}{% include "icons/question.svg" %}{% endset -%}
{%- set row_icons = {"eye_open": _eye_open, "eye_closed": _eye_closed, "question": _question} -%}

{#- Macro: render any section -#}
{%- macro render_section(s) -%}
<div class="section"><div class="section-title">{{ s.title }}{% if s.toggle %} {{ tri_toggle(s.toggle) }}{% endif %}{% if s.layout_toggle %} {{ tri_toggle(s.layout_toggle) }}{% endif %}</div>
{%- if s.empty -%}
<div class="section-row"><span class="row-label"> </span><div class="card-row"><div class="empty-card">empty</div></div></div>
{%- elif s.toggle -%}
<div id="{{ s.section_id }}"{% if s.toggle and s.toggle.default_mode == "none" %} style="display:none"{% endif %}{% if s.toggle and s.toggle.default_mode == "unknown" %} class="mode-unknown"{% endif %}>
{%- if s.layout_toggle -%}
<div class="layout-wide" data-list="{{ s.section_id }}"{% if s.layout_toggle.default_mode == "tall" %} style="display:none"{% endif %}>
{%- for row in s.rows -%}
{{ section_row(row, row_icons, cards_rel, icons_rel, s.mark_resolved) }}
{%- endfor -%}
</div><div class="layout-tall" data-list="{{ s.section_id }}"{% if s.layout_toggle.default_mode != "tall" %} style="display:none"{% endif %}>
<table class="tall-grid">
{%- for row in s.rows -%}
{%- set num_rows = (row.cards|length + s.column_count - 1) // s.column_count -%}
{%- for r in range(num_rows) -%}
<tr{% if row.all_known %} class="all-known"{% endif %}>
{%- if loop.first -%}
<td class="row-label" rowspan="{{ num_rows }}">{{ row.label }}</td>
{%- endif -%}
{%- for c in range(s.column_count) -%}
{%- set idx = c * num_rows + r if s.arrange_by_columns else r * s.column_count + c -%}
<td>{% if idx < row.cards|length and row.cards[idx] %}{{ render_item(row.cards[idx], cards_rel, icons_rel, s.mark_resolved) }}{% endif %}</td>
{%- endfor -%}
</tr>
{%- endfor -%}
{%- endfor -%}
</table>
</div>
{%- else -%}
{%- for row in s.rows -%}
{{ section_row(row, row_icons, cards_rel, icons_rel, s.mark_resolved) }}
{%- endfor -%}
{%- endif -%}
</div>
{%- else -%}
{%- for row in s.rows -%}
{{ section_row(row, row_icons, cards_rel, icons_rel, s.mark_resolved) }}
{%- endfor -%}
{%- endif -%}
</div>
{%- endmacro -%}

{#- Page content: columns -#}
{%- set list_ids = ["base-list", "cities-list"] -%}
{%- if columns|length == 1 -%}
{%- for s in columns[0] %}
{{ render_section(s) }}
{%- endfor -%}
{%- else -%}
<div class="page-grid" style="grid-template-columns: {% for col in columns %}{% if col | selectattr('section_id', 'in', list_ids) | list %}auto{% else %}1fr{% endif %}{% if not loop.last %} {% endif %}{% endfor %};">
{%- for col in columns -%}
<div class="page-col">
{%- for s in col %}
{{ render_section(s) }}
{%- endfor -%}
</div>
{%- endfor -%}
</div>
{%- endif -%}

<script>
{% include "summary.js" %}
</script>
</body>
</html>
