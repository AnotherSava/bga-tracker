{
  "manifest_version": 3,
  "name": "BGA Assistant",
  "version": "1.0.0",
  "description": "Game assistant for Board Game Arena.",
  "permissions": ["activeTab", "scripting", "sidePanel", "tabs"],
  "host_permissions": ["https://boardgamearena.com/*", "https://*.boardgamearena.com/*"],
  "action": {
    "default_icon": {
      "16": "assets/extension/icon-16-0.png",
      "48": "assets/extension/icon-48-0.png",
      "128": "assets/extension/icon-128-0.png"
    },
    "default_title": "BGA Assistant"
  },
  "icons": {
    "16": "assets/extension/icon-16-0.png",
    "48": "assets/extension/icon-48-0.png",
    "128": "assets/extension/icon-128-0.png"
  },
  "commands": {
    "toggle-sidepanel": {
      "description": "Toggle side panel"
    }
  },
  "minimum_chrome_version": "141",
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "dist/sidepanel.html"
  }
}
