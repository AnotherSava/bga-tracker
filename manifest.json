{
  "manifest_version": 3,
  "name": "BGA Assistant",
  "version": "1.0",
  "description": "Game assistant for Board Game Arena.",
  "permissions": ["activeTab", "scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": ["https://boardgamearena.com/*", "https://*.boardgamearena.com/*"],
  "action": {
    "default_icon": {
      "16": "assets/extension/icon-16.png",
      "48": "assets/extension/icon-48.png",
      "128": "assets/extension/icon-128.png"
    },
    "default_title": "BGA Assistant"
  },
  "icons": {
    "16": "assets/extension/icon-16.png",
    "48": "assets/extension/icon-48.png",
    "128": "assets/extension/icon-128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+B"
      },
      "description": "Toggle side panel"
    }
  },
  "minimum_chrome_version": "141",
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "dist/sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/bga/innovation/*"],
      "matches": ["https://boardgamearena.com/*", "https://*.boardgamearena.com/*"]
    }
  ]
}
